[Unit]
Description=AI Robot read-only dashboard API
After=network-online.target ai-robot-paper.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/typbing/ai_robot
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/home/typbing/.config/ai_robot/env
ExecStart=/usr/bin/python3 -u -m ai_robot.dashboard_server --config config.live.json --host 100.94.190.35 --port 8787
Restart=always
RestartSec=15

[Install]
WantedBy=default.target
