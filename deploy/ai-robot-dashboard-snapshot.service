[Unit]
Description=Publish sanitized AI Robot dashboard snapshot
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/typbing/ai_robot
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/home/typbing/.config/ai_robot/env
ExecStart=/usr/bin/python3 -m ai_robot.publish_dashboard_snapshot --config config.live.json --docs-dir docs --checkout-dir /home/typbing/ai_robot_gh_pages
